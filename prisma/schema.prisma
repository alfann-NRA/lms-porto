datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("STUDENT") // STUDENT, TEACHER, PARENT
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  classesTaught Class[]      @relation("TeacherClasses")
  classes       Class[]      @relation("StudentClasses")
  submissions   Submission[]
  comments      Comment[]
  attendances   AttendanceRecord[]
  quizAttempts  QuizAttempt[]
}

model Class {
  id          String       @id @default(cuid())
  name        String
  description String?
  teacherId   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  teacher     User         @relation("TeacherClasses", fields: [teacherId], references: [id])
  students    User[]       @relation("StudentClasses")
  assignments Assignment[]
  attendances Attendance[]
  virtualClasses VirtualClass[]
  discussions Discussion[]
  quizzes     Quiz[]
  modules     Module[]
}

model Assignment {
  id          String       @id @default(cuid())
  title       String
  description String
  dueDate     DateTime
  classId     String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  class       Class        @relation(fields: [classId], references: [id])
  submissions Submission[]
}

model Submission {
  id           String   @id @default(cuid())
  content      String?
  fileUrl      String?
  grade        Float?
  status       String   @default("PENDING") // PENDING, GRADED, LATE
  studentId    String
  assignmentId String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  student      User       @relation(fields: [studentId], references: [id])
  assignment   Assignment @relation(fields: [assignmentId], references: [id])
}

// === NEW EDLINK FEATURES ===

model Attendance {
  id          String   @id @default(cuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  date        DateTime @default(now())
  isOpen      Boolean  @default(true)
  records     AttendanceRecord[]
}

model AttendanceRecord {
  id           String     @id @default(cuid())
  attendanceId String
  attendance   Attendance @relation(fields: [attendanceId], references: [id], onDelete: Cascade)
  studentId    String
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  status       String     @default("PRESENT") // PRESENT, LATE, EXCUSED
  time         DateTime   @default(now())
}

model VirtualClass {
  id          String   @id @default(cuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  title       String
  platform    String   @default("ZOOM") // ZOOM, GMEET
  meetingLink String
  startTime   DateTime
  createdAt   DateTime @default(now())
}

model Discussion {
  id          String   @id @default(cuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  title       String
  content     String
  comments    Comment[]
  createdAt   DateTime @default(now())
}

model Comment {
  id           String     @id @default(cuid())
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  content      String
  createdAt    DateTime   @default(now())
}

model Quiz {
  id          String   @id @default(cuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  title       String
  durationMin Int      @default(60)
  questions   Question[]
  attempts    QuizAttempt[]
  createdAt   DateTime @default(now())
}

model Question {
  id          String   @id @default(cuid())
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  text        String
  optionA     String
  optionB     String
  optionC     String
  optionD     String
  correctOpt  String   // 'A', 'B', 'C', or 'D'
}

model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId   String
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score       Int      @default(0)
  finishedAt  DateTime @default(now())
}

model Module {
  id          String   @id @default(cuid())
  classId     String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  title       String
  content     String   // text or markdown content
  fileUrl     String?  // optional PDF/Video link
  createdAt   DateTime @default(now())
}
